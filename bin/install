#!/usr/bin/env bash
set -euo pipefail

mkdir -p "${ASDF_INSTALL_PATH}/bin"

# Copy all binaries from download path
find "${ASDF_DOWNLOAD_PATH}" -type f -executable -exec cp {} "${ASDF_INSTALL_PATH}/bin/" \;

# Create devsbill -> dbill alias
if [ -f "${ASDF_INSTALL_PATH}/bin/dbill" ]; then
  ln -sf dbill "${ASDF_INSTALL_PATH}/bin/devsbill"
fi

# Ensure all binaries are executable
chmod +x "${ASDF_INSTALL_PATH}/bin/"*

echo "Installed to ${ASDF_INSTALL_PATH}/bin"
